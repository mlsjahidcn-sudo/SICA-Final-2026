# SICA - Hostinger Apache/LiteSpeed Configuration
# Serve static files directly, proxy dynamic requests to Node.js on port 5000

# Disable ALL LiteSpeed caching and optimization for dynamic requests
<IfModule litespeed.c>
    CacheEngine off
    NoCache *
    LiteSpeedConf Off
    RewriteEngine On
    RewriteRule .* - [E=noabort:1]
    RewriteRule .* - [E=noconntimeout:1]
</IfModule>

# Disable mod_deflate to avoid conflicts with Node.js compression
<IfModule mod_deflate.c>
    SetOutputFilter DEFLATE
    RemoveOutputFilter DEFLATE
</IfModule>

# Disable mod_ratelimit completely
<IfModule mod_ratelimit.c>
    SetOutputFilter RATE_LIMIT
    RemoveOutputFilter RATE_LIMIT
</IfModule>

# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Disable rewrite logs
    RewriteLogLevel 0
    
    # ============================================================
    # Step 1: Serve static files directly from /public
    # ============================================================
    # If the file exists in /public, serve it directly
    RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
    RewriteRule ^(.*)$ /public/$1 [L]
    
    # ============================================================
    # Step 2: Proxy everything else to Node.js on port 5000
    # ============================================================
    # Proxy to Node.js application - disable buffering
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ http://localhost:5000/$1 [P,L,QSA,E=noabort:1,E=noconntimeout:1]
    
    # Also proxy any remaining requests (like existing files/dirs that aren't in public)
    RewriteRule ^(.*)$ http://localhost:5000/$1 [P,L,QSA,E=noabort:1,E=noconntimeout:1]
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    # Only set no-cache for dynamic requests, let static files be cached
    <FilesMatch "\.(html|htm|json|xml)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    # Cache static assets for 1 year
    <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|js|css|swf|svg|woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
</IfModule>

# Disable server signature
ServerSignature Off