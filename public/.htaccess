# SICA - Hostinger Apache/LiteSpeed Configuration
# Proxy all requests to Node.js app running on port 5000

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Proxy to Node.js application
    RewriteRule ^(.*)$ http://localhost:5000/$1 [P,L]
</IfModule>

# Increase rate limit thresholds for API-heavy application
<IfModule mod_ratelimit.c>
    SetOutputFilter RATE_LIMIT
    LimitRate 0
</IfModule>

# Disable Hostinger's default rate limiting for this site
<IfModule litespeed.c>
    CacheEngine off
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>
